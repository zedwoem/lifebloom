{
  "crons": [
    {
      "path": "/api/cron/price-sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/rss-ingest",
      "schedule": "0 */8 * * *"
    },
    {
      "path": "/api/cron/affiliate-refresh",
      "schedule": "0 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
