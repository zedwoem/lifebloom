# environment_variables_template.properties
# LifeBloom Hub — Enterprise Environment Variables & Configuration
# 
# PANDUAN PENGGUNAAN (SOP DEV & DEPLOYMENT):
# 1. Gandakan (copy) file ini menjadi `.env.local` untuk development lokal.
# 2. JANGAN PERNAH me-commit `.env.local`, `.env.production`, atau file kredensial ke Git.
# 3. Kunci yang memiliki prefix `NEXT_PUBLIC_` bersifat EKSPLISIT dan akan diekspos ke klien (browser).
#    Dilarang keras meletakkan *Secret Keys* atau kredensial API ke dalam variabel ber-prefix ini.
# 4. Kunci tanpa prefix `NEXT_PUBLIC_` adalah *Server-Side Secrets* (Hanya diakses oleh Node.js, Deno Edge, atau Next.js API Routes).
# 5. Di lingkungan produksi (Vercel): Masukkan seluruh variabel ke Vercel Settings -> Environment Variables.
#
# LEGEND:
# [REQUIRED]      = Sistem akan crash atau gagal build jika kosong.
# [OPTIONAL]      = Fitur akan mengalami degradasi mulus (graceful degradation) jika dikosongkan.
# [AUTO-VERCEL]   = Di-inject otomatis oleh Vercel CI/CD, tidak perlu di-set secara manual.

# ============================================================
# 1. NEXT.JS CORE SYSTEM & ROUTING
# ============================================================

# [AUTO-VERCEL] URL dasar deployment (e.g., https://lifebloomhub.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# [REQUIRED] Bahasa utama untuk i18n
NEXT_PUBLIC_DEFAULT_LOCALE=en

# [REQUIRED] Secret string panjang (minimal 32 char) untuk mengamankan revalidasi ISR (Incremental Static Regeneration).
# Digunakan untuk menghapus cache halaman Edge secara manual setelah pembaruan database tanpa perlu re-deploy.
# Generate: openssl rand -base64 32
REVALIDATE_TOKEN=your_revalidate_token_here

# [REQUIRED] Mock Auth Mode (true untuk development tanpa login DB, false untuk production)
NEXT_PUBLIC_USE_MOCK_AUTH=false

# ============================================================
# 2. SUPABASE (DATABASE, AUTH, STORAGE, EDGE FUNCTIONS)
# ============================================================
# Dapatkan dari: https://supabase.com/dashboard -> Project -> Settings -> API

# [REQUIRED] Public URL (Digunakan oleh frontend & backend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# [REQUIRED] Public Anon Key (Digunakan frontend, dibatasi oleh Row Level Security/RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# [REQUIRED-SERVER] Service Role Key (Bypass RLS - HANYA UNTUK CRON & SERVER SIDE)
# WARNING: Kebocoran key ini memberikan hak akses admin penuh ke database!
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# [OPTIONAL] Nama bucket storage untuk unggahan user (avatar, dll)
SUPABASE_STORAGE_BUCKET=lifebloom-assets

# ============================================================
# 3. KECERDASAN BUATAN (AI / LLM PROVIDERS & TRANSLATION)
# ============================================================
# LifeBloom menggunakan model AI berlapis (fallback system) untuk ingest konten, terjemahan, dan NLP.

# [REQUIRED-SERVER] GROK / xAI API KEY (API AI UTAMA)
# Digunakan sebagai mesin AI utama untuk analisis sentimen, perumusan artikel, dan NLP murah & cepat.
XAI_API_KEY=your_grok_xai_api_key

# [REQUIRED-SERVER] GEMINI API KEY (AI STUDIO) (Fallback 1)
# Digunakan untuk tugas analitis mendalam, penalaran kompleks, dan ekstraksi data terstruktur panjang.
GEMINI_API_KEY=your_gemini_api_key

# [OPTIONAL-SERVER] OPENAI API KEY (Fallback 2 / Embeddings)
# Digunakan untuk pembuatan vector embeddings.
OPENAI_API_KEY=your_openai_api_key

# [OPTIONAL] DeepL API Key untuk TranslationService Adapter
DEEPL_API_KEY=your_deepl_api_key

# [OPTIONAL] LibreTranslate (Fallback Translation)
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=your_libretranslate_api_key

# ============================================================
# 4. PAYMENT GATEWAYS (STRIPE & PAYPAL)
# ============================================================
# Digunakan jika ada fitur premium, langganan kalkulator pro, atau dukungan/donasi.

# -- STRIPE --
# [REQUIRED-SERVER] Secret key Stripe untuk proses pembayaran dan verifikasi webhook
STRIPE_SECRET_KEY=your_stripe_secret_key
# [OPTIONAL-CLIENT] Publishable key Stripe untuk merender elemen kartu di frontend
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
# [REQUIRED-SERVER] Secret webhook untuk memverifikasi event Stripe (payment_intent.succeeded)
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# -- PAYPAL --
# [OPTIONAL-SERVER] PayPal Client ID & Secret
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# Tipe env: 'sandbox' atau 'production'
PAYPAL_ENVIRONMENT=sandbox

# ============================================================
# 5. SOCIAL MEDIA AUTO-POSTING (THE VIRAL GROWTH ENGINE)
# ============================================================
# Digunakan oleh Deno Edge Cron Jobs untuk menyebarkan penurunan harga/artikel baru.

# -- PINTEREST (Visual/Infographics) --
PINTEREST_APP_ID=your_pinterest_app_id
PINTEREST_APP_SECRET=your_pinterest_app_secret
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token
PINTEREST_BOARD_ID=your_default_board_id

# -- THREADS (Meta) --
THREADS_ACCESS_TOKEN=your_threads_access_token
THREADS_USER_ID=your_threads_user_id

# -- MASTODON (Fediverse) --
MASTODON_ACCESS_TOKEN=your_mastodon_access_token
MASTODON_API_URL=https://mastodon.social/api/v1/

# -- BLUESKY (AT Protocol) --
BLUESKY_HANDLE=your_handle_bsky_social
BLUESKY_PASSWORD=your_app_password

# ============================================================
# 6. CACHING & IN-MEMORY STORE (REDIS / UPSTASH)
# ============================================================
# Digunakan untuk Rate-Limiting API, deduplikasi Cron Job, dan caching sesi sementara.

# [OPTIONAL-SERVER] Koneksi ke Redis (misal: Upstash)
KV_REST_API_URL=https://your_database_upstash_io
KV_REST_API_TOKEN=your_upstash_token

# ============================================================
# 7. LOGGING, MONITORING & APM (APPLICATION PERFORMANCE MONITORING)
# ============================================================

# -- SENTRY (Frontend/Edge Error Tracking) --
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# -- DATADOG (Log Aggregation & Server Metrics) --
DATADOG_API_KEY=your_datadog_api_key
DATADOG_SITE=datadoghq.com

# -- NEW RELIC (APM Alternative) --
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
NEW_RELIC_APP_NAME=LifeBloomHub

# ============================================================
# 8. EMAIL & NOTIFICATIONS
# ============================================================

# -- RESEND (Email Transaksional Utama) --
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=hello@lifebloom.io

# -- SENDGRID (Email Fallback / Bulk Marketing) --
SENDGRID_API_KEY=your_sendgrid_api_key

# -- TWILIO (SMS / WhatsApp Alerts - Opsional) --
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# -- TELEGRAM (Sistem Peringatan Admin Internal) --
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_telegram_chat_id

# ============================================================
# 9. AFFILIATE NETWORKS (MONETIZATION SYSTEM)
# ============================================================

# [REQUIRED] Amazon Associates (Product Advertising API)
AFFILIATE_AMAZON_ACCESS_KEY=your_amazon_access_key
AFFILIATE_AMAZON_SECRET_KEY=your_amazon_secret_key
AFFILIATE_AMAZON_PARTNER_TAG=your_amazon_partner_tag
AFFILIATE_AMAZON_REGION=us-east-1
AMAZON_AFFILIATE_ID=your_amazon_affiliate_id

# [OPTIONAL] Chewy (Pet Pillar)
AFFILIATE_CHEWY_API_KEY=your_chewy_api_key
CHEWY_AFFILIATE_ID=your_chewy_affiliate_id

# [OPTIONAL] Travelpayouts (Travel Pillar)
AFFILIATE_TRAVELPAYOUTS_TOKEN=your_travelpayouts_token

# ============================================================
# 10. NEW INTEGRATIONS (TTS, TRAVEL, PETS, HEALTH)
# ============================================================

# [AUDIO STREAMING]
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# [TRAVEL & FLIGHTS]
AMADEUS_CLIENT_ID=your_amadeus_api_key_here
AMADEUS_CLIENT_SECRET=your_amadeus_secret_here
AMADEUS_MOCK_TOKEN=your_amadeus_mock_token

# [PET FINDER]
PETFINDER_API_KEY=your_petfinder_api_key_here
PETFINDER_SECRET_KEY=your_petfinder_secret_here
PETFINDER_MOCK_TOKEN=your_petfinder_mock_token

# [OPENFDA / RXNAV - Opsional, batas rate limit tinggi]
OPENFDA_API_KEY=your_openfda_api_key_here

# ============================================================
# 11. SECURITY & CRON AUTHORIZATION
# ============================================================

# [REQUIRED] Secret token untuk mengotentikasi pemanggilan fungsi Supabase Cron (Edge)
# Mencegah eksekusi endpoint auto-posting atau RSS ingest oleh pihak luar.
CRON_SECRET=your_cron_secret_here

# ============================================================
# 12. DEVELOPMENT & FEATURE FLAGS
# ============================================================

# NEXT_PUBLIC_FEATURE_ flags mengatur rilis fungsionalitas di UI.
NEXT_PUBLIC_FEATURE_PINTEREST_AUTO_PIN=true
NEXT_PUBLIC_FEATURE_THREADS_AUTO_POST=true
NEXT_PUBLIC_FEATURE_EMBED_WIDGETS=true
NEXT_PUBLIC_FEATURE_SEASONAL_CONTENT=true
NEXT_PUBLIC_MAINTENANCE_MODE=false

# CYPRESS_TESTING_BYPASS=true
GNEWS_API_KEY=

# ============================================================
# 13. TALLY.SO INTEGRATIONS
# ============================================================
NEXT_PUBLIC_TALLY_PARTNERSHIP_FORM_URL=https://tally.so/embed/your_form_id?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1
TALLY_API_KEY=your_tally_api_key_here


